# Environment Configuration

# WATI API (only needed if USE_MOCK=false)
WATI_API_ENDPOINT=https://live-server-123.wati.io
WATI_TOKEN=your_api_token

# LLM Configuration - Multi-model routing
LLM_PARSE_MODEL=deepseek-chat
LLM_PLAN_MODEL=deepseek-chat
LLM_CLARIFY_MODEL=deepseek-chat

# API Keys (only the one you're using needs to be set)
DEEPSEEK_API_KEY=your_deepseek_key
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Mode
USE_MOCK=true
DRY_RUN_DEFAULT=false

# Ticket Management
TICKET_REPORTER=Zachary

# Rate Limiting
MAX_REQUESTS_PER_SECOND=10
MAX_CONCURRENT_REQUESTS=5

# Logging
LOG_LEVEL=INFO
